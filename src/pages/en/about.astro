import qvsbase from "../../assets/qvsbase.png";
import huggingface from "../../assets/hf.webp";
import spic from "../../assets/spic.png";

export const siteTitle = "Junya Morioka";
export const description = "Technical notes from an engineer";
export const author = "Junya Morioka";

let posts = await getCollection("posts_en");
posts = posts.sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
